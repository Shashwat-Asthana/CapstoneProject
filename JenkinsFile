pipeline {
    agent any
    tools {
        nodejs 'NodeJS-20'
    }
    environment {
        VERCEL_HOOK = credentials('vercel-deploy-hook')
    }
    
    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Install') {
            steps {
                sh 'npm install'
                // Install Vitest if not already in package.json
                sh 'npm install -D vitest || echo "Vitest already installed"'
            }
        }

        stage('Build') {
            steps {
                sh 'npm run build'
            }
        }

        stage('Test with Vitest') {
            steps {
                script {
                    // Check if test script exists and contains "vitest"
                    def hasVitest = sh(
                        script: 'npm run | grep -q "vitest"',
                        returnStatus: true
                    ) == 0
                    
                    if (hasVitest) {
                        // Run tests with coverage and JUnit output
                        sh '''
                            npx vitest run --coverage --reporter=junit \
                            --outputFile=test-results.xml
                        '''
                    } else {
                        echo 'No Vitest tests found in package.json'
                    }
                }
            }
            post {
                always {
                    // Publish test results even if tests fail
                    junit 'test-results.xml'
                    
                    // Publish coverage report if generated
                    publishHTML target: [
                        allowMissing: true,
                        alwaysLinkToLastBuild: true,
                        keepAll: true,
                        reportDir: 'coverage',
                        reportFiles: 'index.html',
                        reportName: 'Vitest Coverage Report'
                    ]
                }
            }
        }

        stage('Deploy') {
            steps {
                script {
                    echo 'Triggering Vercel deployment...'
                    sh 'curl -s -X POST "$VERCEL_HOOK"'
                }
            }
        }
    }
    
    post {
        success {
            echo '✅ Pipeline succeeded!'
        }
        failure {
            echo '❌ Pipeline failed!'
        }
    }
}