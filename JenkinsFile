pipeline {
    agent {
        docker {
            image 'node:20-alpine'  // Lightweight Node.js image
            args '-u root'  // Run as root to avoid permission issues
        }
    }
    environment {
        VERCEL_HOOK = credentials('vercel-deploy-hook')
        CI = 'true'
    }
    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }
        
        stage('Install Dependencies') {
            steps {
                sh 'npm install'
            }
        }
        
        stage('Run Tests') {
            steps {
                sh 'npm test -- --watchAll=false'
            }
        }
        
        stage('Build') {
            steps {
                sh 'npm run build'
            }
        }
        
        stage('Deploy to Vercel') {
            steps {
                sh "curl -X POST '$VERCEL_HOOK'"
            }
        }
    }
}