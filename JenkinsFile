pipeline {
    agent any
    
    // Only include tools if NodeJS-20 is properly configured in Jenkins
    tools {
        nodejs 'NodeJS-20' 
    }
    
    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Install') {
            steps {
                sh 'npm install'
                // Optional: Only install Vitest if needed
                sh 'npm list vitest || npm install -D vitest'
            }
        }

        stage('Build') {
            steps {
                sh 'npm run build'
            }
        }

        stage('Test') {
            steps {
                script {
                    // Check if test script exists
                    def hasTests = sh(
                        script: 'npm run | grep -qE "\\b(test|vitest)\\b"',
                        returnStatus: true
                    ) == 0
                    
                    if (hasTests) {
                        // Run tests with coverage
                        sh '''
                            npx vitest run --coverage || true
                        '''
                    } else {
                        echo 'No tests found in package.json'
                    }
                }
            }
            post {
                always {
                    // Publish test results if they exist
                    junit 'test-results.xml' 
                    
                    // Publish coverage report if generated
                    publishHTML target: [
                        allowMissing: true,
                        reportDir: 'coverage',
                        reportFiles: 'index.html',
                        reportName: 'Coverage Report'
                    ]
                }
            }
        }

        stage('Deploy') {
            when {
                branch 'main'
            }
            steps {
                script {
                    // Verify credential exists before attempting deployment
                    def hasCredential = false
                    try {
                        withCredentials([string(credentialsId: 'vercel-deploy-hook', variable: 'DEPLOY_HOOK')]) {
                            hasCredential = true
                        }
                    } catch (Exception e) {
                        error "Vercel deployment hook credential 'vercel-deploy-hook' not found. Please add it in Jenkins credentials."
                    }
                    
                    if (hasCredential) {
                        withCredentials([string(credentialsId: 'vercel-deploy-hook', variable: 'DEPLOY_HOOK')]) {
                            echo 'Triggering Vercel deployment...'
                            sh 'curl -s -X POST "$DEPLOY_HOOK"'
                            echo 'Deployment triggered successfully'
                        }
                    }
                }
            }
        }
    }
    
    post {
        success {
            echo '✅ Pipeline succeeded!'
        }
        failure {
            echo '❌ Pipeline failed!'
        }
        always {
            // Clean up workspace (safe version)
            script {
                if (env.NODE_NAME) {  // Only runs on agent nodes
                    cleanWs()
                }
            }
        }
    }
}