pipeline {
    agent any
    tools {
        nodejs 'NodeJS-20'
    }
    environment {
        VERCEL_HOOK = credentials('vercel-deploy-hook')
    }
    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Install') {
            steps {
                sh 'npm install'
            }
        }

        stage('Build') {
            steps {
                sh 'npm run build'
            }
        }

        stage('Test') {
            when {
                expression {
                    sh(script: 'npm run | grep -q " test "', returnStatus: true) == 0
                }
            }
            steps {
                sh 'npm test'
            }
        }

        stage('Deploy') {
            when {
                branch 'main'
            }
            steps {
                script {
                    echo 'Triggering Vercel deployment...'
                    sh 'curl -s -X POST "$VERCEL_HOOK"'
                }
            }
        }
    }
    post {
        success {
            echo '✅ Pipeline succeeded!'
        }
        failure {
            echo '❌ Pipeline failed!'
        }
    }
}